# ============================================================================
# MANGU Publishers — Environment Variables (TEMPLATE — no real secrets)
# ============================================================================
# Copy: cp .env.local.example .env.local
# Validate: npm run validate-env
# Sync to GCP: ./scripts/sync-gcp-secrets-from-env.sh (after gcloud auth login)
#
# REQUIRED for local dev + production deploy:
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
#   NEXT_PUBLIC_SITE_URL
#   UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN (production rate limiting)
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase Configuration [PHASE 1 - REQUIRED]
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# Stripe Configuration [PHASE 1 - REQUIRED]
# ----------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys for development: pk_test_... and sk_test_...
# Use live keys for production: pk_live_... and sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret for verifying Stripe webhook signatures
# Get this from: https://dashboard.stripe.com/webhooks
# For local development, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhook
# For production: Create webhook endpoint pointing to https://your-domain.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ----------------------------------------------------------------------------
# Application Configuration [PHASE 1 - REQUIRED]
# ----------------------------------------------------------------------------
# Base URL of your application
# For local development: http://localhost:3000
# For production (Cloud Run / Vercel): https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Node environment (development, production, test)
# Usually set automatically by Next.js
NODE_ENV=development

# ----------------------------------------------------------------------------
# Upstash Redis (REQUIRED for distributed rate limiting in production)
# ----------------------------------------------------------------------------
# Create a Redis database at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ----------------------------------------------------------------------------
# OpenAI Configuration [PHASE 2 - OPTIONAL]
# ----------------------------------------------------------------------------
# Required for AI-powered recommendations (Resonance Engine)
# Get this from: https://platform.openai.com/api-keys
# Can be added in Phase 2 deployment
# OPENAI_API_KEY=sk-proj-...

# ----------------------------------------------------------------------------
# Email Configuration [PHASE 2 - OPTIONAL]
# ----------------------------------------------------------------------------
# Required for sending email notifications
# Get this from: https://resend.com/api-keys
# Can be added in Phase 2 deployment
# RESEND_API_KEY=re_...

# ----------------------------------------------------------------------------
# Development-Only Variables
# ----------------------------------------------------------------------------
# Set to 'true' to enable mock mode (bypasses external services)
# USE_MOCKS=false

# Set to 'true' to skip email sending in development
# SKIP_EMAILS=false
