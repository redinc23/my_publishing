# ============================================================================
# MANGU Publishers — Environment Variables (TEMPLATE — no real secrets)
# ============================================================================
# Copy: cp .env.local.example .env.local
# Validate: npm run validate-env
# Deploy target: Vercel project environment variables
#
# GCP Secret Manager mapping (env var → secret name in cloudbuild.yaml --set-secrets):
#   SUPABASE_SERVICE_ROLE_KEY  → supabase-service-role-key
#   STRIPE_SECRET_KEY          → stripe-secret-key
#   STRIPE_WEBHOOK_SECRET      → stripe-webhook-secret
#   RESEND_API_KEY             → resend-api-key (optional)
#   OPENAI_API_KEY             → openai-api-key (optional)
#   UPSTASH_REDIS_REST_URL     → upstash-redis-rest-url (optional)
#   UPSTASH_REDIS_REST_TOKEN   → upstash-redis-rest-token (optional)
# Canonical GCP: project delta-wonder-488420-i3, region us-central1, service mangu-publishers
#
# REQUIRED for local dev + production deploy:
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
#   NEXT_PUBLIC_SITE_URL
#   UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN (production rate limiting)
# ============================================================================

# ----------------------------------------------------------------------------
# MongoDB Atlas [ADR-002 — AUTOMATE with: npm run db:mongo:up]
# ----------------------------------------------------------------------------
# One-time keys (not the cluster connection string):
#   Atlas → Organization → Access Manager → API Keys
#   Vercel → Account → Tokens
# Then:
#   export ATLAS_PUBLIC_KEY=... ATLAS_PRIVATE_KEY=... VERCEL_TOKEN=...
#   npm run db:mongo:up
# That writes MONGODB_URI, opens 0.0.0.0/0, ensures indexes, syncs Vercel.
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
# ATLAS_ORG_ID=
# ATLAS_GROUP_ID=
# ATLAS_CLUSTER_NAME=Cluster0
# ATLAS_DB_USER=mangu_app
VERCEL_TOKEN=
# VERCEL_PROJECT_ID=prj_6FYYVNpwHAwJCErSchMZksCiiPul
# VERCEL_TEAM_ID=team_hc9sovtwUu2WJdNuoU7JtWUP
#
# Written by db:atlas:bootstrap (do not hand-edit unless importing an existing URI):
MONGODB_URI=mongodb+srv://USER:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=mangu
DATABASE_PROVIDER=mongodb

# ----------------------------------------------------------------------------
# Supabase Configuration [LEGACY — still required until Mongo + auth cutover]
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
# Keys are JWT tokens starting with "eyJ..." (not sb_publishable_ / sb_secret_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# Stripe Configuration [PHASE 1 - REQUIRED]
# ----------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys for development: pk_test_... and sk_test_...
# Use live keys for production: pk_live_... and sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret for verifying Stripe webhook signatures
# Get this from: https://dashboard.stripe.com/webhooks
# For local development, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhook
# For production: Create webhook endpoint pointing to https://your-domain.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ----------------------------------------------------------------------------
# Application Configuration [PHASE 1 - REQUIRED]
# ----------------------------------------------------------------------------
# Base URL of your application
# Local dev: http://localhost:3000
# Production / prod-testing: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Next.js sets NODE_ENV automatically — do not set NODE_ENV=production here.
# NODE_ENV=development

# ----------------------------------------------------------------------------
# Upstash Redis (REQUIRED for distributed rate limiting in production)
# ----------------------------------------------------------------------------
# Create a Redis database at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ----------------------------------------------------------------------------
# Sentry Configuration [PHASE 2 - OPTIONAL — recommended for production]
# ----------------------------------------------------------------------------
# 1. Create project: https://sentry.io → Create project → Next.js
# 2. Copy DSN from Settings → Client Keys (DSN)
# 3. Paste into NEXT_PUBLIC_SENTRY_DSN (same value for client + server)
# 4. Optional source maps in CI: create auth token → SENTRY_AUTH_TOKEN → sync to GCP
# Full guide: docs/OPTIONAL_SERVICES_SETUP.md
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ----------------------------------------------------------------------------
# OpenAI Configuration [PHASE 2 - OPTIONAL]
# ----------------------------------------------------------------------------
# Required for AI-powered recommendations (Resonance Engine)
# Get this from: https://platform.openai.com/api-keys
# Can be added in Phase 2 deployment
# OPENAI_API_KEY=sk-proj-...

# ----------------------------------------------------------------------------
# Email Configuration [PHASE 2 - OPTIONAL]
# ----------------------------------------------------------------------------
# Required for sending email notifications
# Get this from: https://resend.com/api-keys
# Can be added in Phase 2 deployment
# RESEND_API_KEY=re_...

# ----------------------------------------------------------------------------
# Optional: Analytics & Monitoring [PHASE 2 - OPTIONAL]
# ----------------------------------------------------------------------------
# Add your analytics keys here if you're using services like:
# - Sentry (error tracking) - see above
# - Vercel Analytics
# - Google Analytics
# NEXT_PUBLIC_SENTRY_DSN=  (moved to dedicated section)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ----------------------------------------------------------------------------
# Development-Only Variables
# ----------------------------------------------------------------------------
# Set to 'true' to enable mock mode (bypasses external services)
# USE_MOCKS=false

# Set to 'true' to skip email sending in development
# SKIP_EMAILS=false

# ----------------------------------------------------------------------------
# MCP Server [OPTIONAL — disabled by default (P0-017, issue #200)]
# ----------------------------------------------------------------------------
# The public MCP transport (/api/mcp/[transport]) returns 404 unless
# MCP_ENABLED=true. When enabled, every request must present
# "Authorization: Bearer <MCP_API_KEY>" and is fail-closed rate limited.
# MCP_ENABLED=true without MCP_API_KEY => fail-closed 404 (never open).
# Generate a key: openssl rand -hex 32
# MCP_ENABLED=true
# MCP_API_KEY=
