# ─────────────────────────────────────────────────────────────
# SINGLE SOURCE OF TRUTH — copy to .env.local and fill values.
# NEVER commit a file that contains real values.
# Rotate keys in GitHub Secrets (SUPABASE_ANON_KEY, SUPABASE_URL)
# and run the sync workflow — Vercel + CI update automatically.
# ─────────────────────────────────────────────────────────────

# Supabase
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Optional: service role key — backend/edge functions ONLY, never expose to browser
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# App
VITE_APP_ENV=development
